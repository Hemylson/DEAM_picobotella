<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- TODO: agregar icono de tipo de reto y campos adicionales -->
        <TextView
            android:id="@+id/tvRetoDescripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Descripción del reto"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnEditarReto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Editar reto"
            android:src="@android:drawable/ic_menu_edit" />

        <ImageButton
            android:id="@+id/btnEliminarReto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar reto"
            android:src="@android:drawable/ic_menu_delete" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
